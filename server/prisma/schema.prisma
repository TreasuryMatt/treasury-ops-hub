generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Division {
  operations
  engineering
  pmso
}

enum ResourceType {
  federal
  contractor
}

enum ProjectStatus {
  in_progress
  on_hold
  completed
}

enum ProjectPriority {
  high
  medium
  low
}

enum AppRole {
  viewer
  editor
  manager
  admin
}

enum UserType {
  staff
  customer
}

enum RequestStatus {
  pending
  approved
  denied
}

enum IntakeStatus {
  draft
  submitted
  under_review
  backlog
  denied
  approved
}

enum IntakeDetermination {
  backlog
  denied
  approved
}

enum RiskProgress {
  open
  assumed
  escalated_to_issue
  mitigated
}

enum RiskCriticality {
  critical
  high
  moderate
  low
}

enum RiskActionStatus {
  red
  yellow
  green
}

// ─── Users (app login) ──────────────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  caiaId           String   @unique @map("caia_id")
  email            String   @unique
  displayName      String   @map("display_name")
  role             AppRole  @default(viewer)
  userType         UserType @default(staff) @map("user_type")
  isIntakeReviewer Boolean  @default(false) @map("is_intake_reviewer")
  isResourceManager Boolean @default(false) @map("is_resource_manager")
  isResourceRequestor Boolean @default(false) @map("is_resource_requestor")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  auditLogs        AuditLog[]
  submittedRequests ResourceRequest[] @relation("RequestSubmitter")
  reviewedRequests  ResourceRequest[] @relation("RequestReviewer")

  // Project Status relations
  statusUpdates       StatusUpdate[]   @relation("StatusUpdateAuthor")
  issueEntries        IssueEntry[]     @relation("IssueEntryAuthor")
  resolvedIssues      IssueEntry[]     @relation("IssueEntryResolver")
  accomplishments     Accomplishment[] @relation("AccomplishmentAuthor")
  uploadedDocuments   Document[]       @relation("DocumentUploader")
  submittedRisks           Risk[]                 @relation("RiskSubmitter")
  riskComments             RiskComment[]          @relation("RiskCommentAuthor")
  notifications            Notification[]            @relation("NotificationRecipient")
  notificationPreferences  NotificationPreference[]  @relation("NotificationPreferenceUser")
  resource                 Resource?                 @relation("ResourceUser")

  // Intake relations
  intakeSubmissions         IntakeSubmission[]        @relation("IntakeSubmitter")
  intakeDeterminations      IntakeSubmission[]        @relation("IntakeDeterminer")
  intakeVersionsCreated     IntakeSubmissionVersion[] @relation("IntakeVersionCreator")
  intakeDocumentsUploaded   IntakeDocument[]          @relation("IntakeDocUploader")

  @@map("users")
}

// ─── Roles (reference data) ─────────────────────────────────────────────────

model Role {
  id        String @id @default(uuid())
  name      String @unique
  sortOrder Int    @default(0) @map("sort_order")

  primaryResources   Resource[] @relation("PrimaryRole")
  secondaryResources Resource[] @relation("SecondaryRole")
  assignments        Assignment[]
  resourceRequests   ResourceRequest[]

  @@map("roles")
}

// ─── Functional Areas ───────────────────────────────────────────────────────

model FunctionalArea {
  id        String    @id @default(uuid())
  name      String    @unique
  division  Division?
  sortOrder Int       @default(0) @map("sort_order")

  resources        Resource[]
  resourceRequests ResourceRequest[]

  @@map("functional_areas")
}

// ─── Products (first-class content type) ────────────────────────────────────

enum ProductType {
  PLATFORM
  APPLICATION
  INTEGRATION
  SERVICE
  MOBILE_APP

  @@map("product_type")
}

enum ProductStatus {
  ACTIVE
  EVALUATING
  PLANNED
  DEPRECATED
  SUNSET

  @@map("product_status_enum")
}

enum ProductCriticality {
  LOW
  MEDIUM
  HIGH
  MISSION_CRITICAL

  @@map("product_criticality")
}

enum HostingModel {
  SAAS
  ON_PREM
  HYBRID
  GOVT_CLOUD
  INTERNAL_HOSTED

  @@map("hosting_model")
}

enum AtoStatus {
  AUTHORIZED
  PENDING
  EXPIRED
  NOT_REQUIRED

  @@map("ato_status")
}

enum FedrampLevel {
  LOW
  MODERATE
  HIGH
  NOT_APPLICABLE

  @@map("fedramp_level")
}

enum DataClassification {
  PUBLIC
  SENSITIVE
  RESTRICTED

  @@map("data_classification")
}

model Product {
  id                 String              @id @default(uuid())
  name               String              @unique
  description        String?
  productType        ProductType         @default(APPLICATION) @map("product_type")
  vendor             String?
  isInternal         Boolean             @default(false) @map("is_internal")
  productStatus      ProductStatus       @default(ACTIVE) @map("product_status")
  criticality        ProductCriticality  @default(MEDIUM)
  hostingModel       HostingModel?       @map("hosting_model")
  platformId         String?             @map("platform_id")
  platform           Product?            @relation("ProductPlatform", fields: [platformId], references: [id])
  childProducts      Product[]           @relation("ProductPlatform")
  productOwner       String?             @map("product_owner")
  technicalOwner     String?             @map("technical_owner")
  primaryUrl         String?             @map("primary_url")
  documentationUrl   String?             @map("documentation_url")
  logoUrl            String?             @map("logo_url")
  userCount          Int?                @map("user_count")
  annualCost         Decimal?            @db.Decimal(15, 2) @map("annual_cost")
  contractExpiry     DateTime?           @map("contract_expiry")
  version            String?
  atoStatus          AtoStatus?          @map("ato_status")
  atoExpiry          DateTime?           @map("ato_expiry")
  fedrampLevel       FedrampLevel?       @map("fedramp_level")
  dataClassification DataClassification? @map("data_classification")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  programs       ProductProgram[]
  statusProjects ProductStatusProject[]
  projects       Project[]

  @@map("products")
}

model ProductProgram {
  productId String  @map("product_id")
  programId String  @map("program_id")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  program   Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@id([productId, programId])
  @@map("product_programs")
}

model ProductStatusProject {
  productId       String        @map("product_id")
  statusProjectId String        @map("status_project_id")
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  statusProject   StatusProject @relation(fields: [statusProjectId], references: [id], onDelete: Cascade)

  @@id([productId, statusProjectId])
  @@map("product_status_projects")
}

// ─── Resources (people) ─────────────────────────────────────────────────────

model Resource {
  id           String       @id @default(uuid())
  resourceType ResourceType @map("resource_type")
  firstName    String       @map("first_name")
  lastName     String       @map("last_name")
  division     Division

  functionalAreaId String?        @map("functional_area_id")
  functionalArea   FunctionalArea? @relation(fields: [functionalAreaId], references: [id])

  // Supervisory chain
  isSupervisor         Boolean  @default(false) @map("is_supervisor")
  opsEngLead           String?  @map("ops_eng_lead")

  supervisorId         String?   @map("supervisor_id")
  supervisor           Resource? @relation("Supervisor", fields: [supervisorId], references: [id])
  supervisedResources  Resource[] @relation("Supervisor")

  secondLineSupervisorId String?   @map("second_line_supervisor_id")
  secondLineSupervisor   Resource? @relation("SecondLineSupervisor", fields: [secondLineSupervisorId], references: [id])
  secondLineReports      Resource[] @relation("SecondLineSupervisor")

  // Federal-specific
  gsLevel    String?  @map("gs_level")
  isMatrixed Boolean? @map("is_matrixed")

  // Contractor-specific
  popStartDate       DateTime? @map("pop_start_date")
  popEndDate         DateTime? @map("pop_end_date")
  popAlertDaysBefore Int?      @map("pop_alert_days_before")

  // Roles
  primaryRoleId   String? @map("primary_role_id")
  primaryRole     Role?   @relation("PrimaryRole", fields: [primaryRoleId], references: [id])
  secondaryRoleId String? @map("secondary_role_id")
  secondaryRole   Role?   @relation("SecondaryRole", fields: [secondaryRoleId], references: [id])

  // Linked system user (optional — enables targeted notifications)
  userId           String?   @unique @map("user_id")
  user             User?     @relation("ResourceUser", fields: [userId], references: [id])

  availableForWork Boolean @default(false) @map("available_for_work")
  notes            String?
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  assignments           Assignment[]
  ownedRisks            Risk[]                  @relation("RiskOwner")
  mitigationStepsOwned  RiskMitigationAction[]  @relation("MitigationStepOwner")

  @@map("resources")
}

// ─── Projects ───────────────────────────────────────────────────────────────

model Project {
  id          String         @id @default(uuid())
  name        String
  productId   String?        @map("product_id")
  product     Product?       @relation(fields: [productId], references: [id])
  priority    ProjectPriority?
  status      ProjectStatus  @default(in_progress)
  startDate   DateTime?      @map("start_date")
  endDate     DateTime?      @map("end_date")
  description          String?
  federalProductOwner  String?  @map("federal_product_owner")
  customerContact      String?  @map("customer_contact")
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  assignments      Assignment[]
  resourceRequests ResourceRequest[]
  statusProject    StatusProject?

  @@unique([name, productId])
  @@map("projects")
}

// ─── Assignments (Resource ↔ Project link with utilization) ─────────────────

model Assignment {
  id              String   @id @default(uuid())
  resourceId      String   @map("resource_id")
  resource        Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  projectId       String   @map("project_id")
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleId          String?  @map("role_id")
  role            Role?    @relation(fields: [roleId], references: [id])
  percentUtilized Float    @default(0) @map("percent_utilized")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  notes           String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([resourceId, projectId, roleId])
  @@map("assignments")
}

// ─── Resource Requests ──────────────────────────────────────────────────────

model ResourceRequest {
  id               String         @id @default(uuid())
  requestorId      String         @map("requestor_id")
  requestor        User           @relation("RequestSubmitter", fields: [requestorId], references: [id])
  projectId        String?        @map("project_id")
  project          Project?       @relation(fields: [projectId], references: [id])
  projectOther     String?        @map("project_other")
  resourceType     ResourceType?  @map("resource_type")
  roleId           String?        @map("role_id")
  role             Role?          @relation(fields: [roleId], references: [id])
  functionalAreaId String?        @map("functional_area_id")
  functionalArea   FunctionalArea? @relation(fields: [functionalAreaId], references: [id])
  percentNeeded    Int?           @map("percent_needed")
  startDate        DateTime?      @map("start_date")
  endDate          DateTime?      @map("end_date")
  notes            String?
  status           RequestStatus  @default(pending)
  reviewedById     String?        @map("reviewed_by_id")
  reviewedBy       User?          @relation("RequestReviewer", fields: [reviewedById], references: [id])
  reviewNote       String?        @map("review_note")
  reviewedAt       DateTime?      @map("reviewed_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@map("resource_requests")
}

// ─── Audit Log ──────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?  @map("actor_id")
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json?
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// ═══════════════════════════════════════════════════════════════════════════════
// PROJECT STATUS — New models for the Project Status feature
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Project Status Enums ──────────────────────────────────────────────────

enum StatusProjectStatus {
  initiated
  green
  yellow
  red
  gray
}

enum UpdateCadence {
  weekly
  biweekly
  monthly
}

enum IssueCategory {
  risk
  issue
  blocker
}

enum NotificationType {
  update_due
  update_overdue
  new_update
  issue_created
  issue_resolved
  issue_reopened
  project_status_changed
  assignment_added
  assignment_removed
  pop_expiring
}

// ─── Project Status Reference Data ──────────────────────────────────────────

model Department {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(true) @map("is_active")

  statusProjects StatusProject[]

  @@map("departments")
}

model StatusPriority {
  id        String  @id @default(uuid())
  name      String  @unique
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  statusProjects StatusProject[]

  @@map("status_priorities")
}

model ExecutionType {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(true) @map("is_active")

  statusProjects StatusProject[]

  @@map("execution_types")
}

model CustomerCategory {
  id       String  @id @default(uuid())
  name     String  @unique
  isActive Boolean @default(true) @map("is_active")

  statusProjects StatusProject[]

  @@map("customer_categories")
}

model RagDefinition {
  id          String  @id @default(uuid())
  color       String  @unique
  label       String
  description String?
  isActive    Boolean @default(true) @map("is_active")

  @@map("rag_definitions")
}

model StatusPhase {
  id        String  @id @default(uuid())
  name      String  @unique
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  statusProjects StatusProject[]

  @@map("status_phases")
}

// ─── Portfolio / Program / Project hierarchy ────────────────────────────────

model Portfolio {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  owner       String?
  budget      Decimal? @db.Decimal(15, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  programs Program[]

  @@map("portfolios")
}

model Program {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  logoUrl      String?  @map("logo_url")
  federalOwner String?  @map("federal_owner")
  portfolioId  String   @map("portfolio_id")
  portfolio    Portfolio @relation(fields: [portfolioId], references: [id])
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  products       ProductProgram[]
  statusProjects StatusProject[]
  risks          Risk[]

  @@map("programs")
}

model StatusProject {
  id                 String              @id @default(uuid())
  name               String
  description        String?
  programId          String              @map("program_id")
  program            Program             @relation(fields: [programId], references: [id])
  staffingProjectId  String?             @unique @map("staffing_project_id")
  staffingProject    Project?            @relation(fields: [staffingProjectId], references: [id])
  federalProductOwner String?            @map("federal_product_owner")
  customerContact     String?            @map("customer_contact")
  departmentId       String?             @map("department_id")
  department         Department?         @relation(fields: [departmentId], references: [id])
  priorityId         String?             @map("priority_id")
  priority           StatusPriority?     @relation(fields: [priorityId], references: [id])
  executionTypeId    String?             @map("execution_type_id")
  executionType      ExecutionType?      @relation(fields: [executionTypeId], references: [id])
  customerCategoryId String?             @map("customer_category_id")
  customerCategory   CustomerCategory?   @relation(fields: [customerCategoryId], references: [id])
  phaseId            String?             @map("phase_id")
  phase              StatusPhase?        @relation(fields: [phaseId], references: [id])
  status             StatusProjectStatus @default(gray)
  plannedStartDate   DateTime?           @map("planned_start_date")
  plannedEndDate     DateTime?           @map("planned_end_date")
  actualStartDate    DateTime?           @map("actual_start_date")
  actualEndDate      DateTime?           @map("actual_end_date")
  funded             Boolean             @default(false)
  updateCadence      UpdateCadence       @default(monthly)
  nextUpdateDue      DateTime?           @map("next_update_due")
  isActive           Boolean             @default(true) @map("is_active")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  phases          ProjectPhase[]
  updates         StatusUpdate[]
  issues          IssueEntry[]
  risks           Risk[]
  accomplishments Accomplishment[]
  documents       Document[]
  products        ProductStatusProject[]
  notifications   Notification[]
  intakeSubmission IntakeSubmission?  @relation("IntakeLinkedProject")

  @@map("status_projects")
}

model ProjectPhase {
  id              String        @id @default(uuid())
  statusProjectId String        @map("status_project_id")
  statusProject   StatusProject @relation(fields: [statusProjectId], references: [id], onDelete: Cascade)
  name            String
  startDate       DateTime      @map("start_date")
  endDate         DateTime      @map("end_date")
  color           String?
  sortOrder       Int           @default(0) @map("sort_order")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@map("project_phases")
}

model StatusUpdate {
  id              String              @id @default(uuid())
  statusProjectId String              @map("status_project_id")
  statusProject   StatusProject       @relation(fields: [statusProjectId], references: [id], onDelete: Cascade)
  authorId        String              @map("author_id")
  author          User                @relation("StatusUpdateAuthor", fields: [authorId], references: [id])
  overallStatus   StatusProjectStatus
  summary         String
  risks           String?
  blockers        String?
  createdAt       DateTime            @default(now()) @map("created_at")

  @@map("status_updates")
}

model IssueEntry {
  id              String        @id @default(uuid())
  statusProjectId String        @map("status_project_id")
  statusProject   StatusProject @relation(fields: [statusProjectId], references: [id], onDelete: Cascade)
  authorId        String        @map("author_id")
  author          User          @relation("IssueEntryAuthor", fields: [authorId], references: [id])
  category        IssueCategory
  text            String
  createdAt       DateTime      @default(now()) @map("created_at")
  resolvedAt      DateTime?     @map("resolved_at")
  resolvedById    String?       @map("resolved_by_id")
  resolvedBy      User?         @relation("IssueEntryResolver", fields: [resolvedById], references: [id])
  resolutionNotes String?       @map("resolution_notes")

  @@map("issue_entries")
}

model RiskCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  risks Risk[]

  @@map("risk_categories")
}

model Risk {
  id              String          @id @default(uuid())
  riskCode        String          @unique @map("risk_code")
  progress        RiskProgress    @default(open)
  programId       String          @map("program_id")
  program         Program         @relation(fields: [programId], references: [id])
  statusProjectId String          @map("status_project_id")
  statusProject   StatusProject   @relation(fields: [statusProjectId], references: [id], onDelete: Cascade)
  categoryId      String          @map("category_id")
  category        RiskCategory    @relation(fields: [categoryId], references: [id])
  spmId           String?         @map("spm_id")
  riskOwnerId     String?         @map("risk_owner_id")
  riskOwner       Resource?       @relation("RiskOwner", fields: [riskOwnerId], references: [id])
  title           String
  statement       String
  criticality     RiskCriticality
  submitterId     String          @map("submitter_id")
  submitter       User            @relation("RiskSubmitter", fields: [submitterId], references: [id])
  dateIdentified  DateTime?       @map("date_identified")
  probability     Float?
  impact          String?
  impactDate      DateTime?       @map("impact_date")
  closureCriteria String?         @map("closure_criteria")
  escalatedAt     DateTime?       @map("escalated_at")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  comments          RiskComment[]
  mitigationActions RiskMitigationAction[]

  @@map("risks")
}

model RiskComment {
  id        String   @id @default(uuid())
  riskId     String   @map("risk_id")
  risk       Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  authorId   String   @map("author_id")
  author     User     @relation("RiskCommentAuthor", fields: [authorId], references: [id])
  text       String
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("risk_comments")
}

model RiskMitigationAction {
  id           String           @id @default(uuid())
  riskId       String           @map("risk_id")
  risk         Risk             @relation(fields: [riskId], references: [id], onDelete: Cascade)
  stepOwnerId  String?          @map("step_owner_id")
  stepOwner    Resource?        @relation("MitigationStepOwner", fields: [stepOwnerId], references: [id])
  title        String
  dueDate      DateTime?        @map("due_date")
  status       RiskActionStatus @default(yellow)
  isComplete   Boolean          @default(false) @map("is_complete")
  sortOrder    Int              @default(0) @map("sort_order")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  @@map("risk_mitigation_actions")
}

model Accomplishment {
  id              String        @id @default(uuid())
  statusProjectId String        @map("status_project_id")
  statusProject   StatusProject @relation(fields: [statusProjectId], references: [id], onDelete: Cascade)
  authorId        String        @map("author_id")
  author          User          @relation("AccomplishmentAuthor", fields: [authorId], references: [id])
  text            String

  createdAt       DateTime      @default(now()) @map("created_at")

  @@map("accomplishments")
}

model Document {
  id              String        @id @default(uuid())
  statusProjectId String        @map("status_project_id")
  statusProject   StatusProject @relation(fields: [statusProjectId], references: [id], onDelete: Cascade)
  uploadedById    String        @map("uploaded_by_id")
  uploadedBy      User          @relation("DocumentUploader", fields: [uploadedById], references: [id])
  filename        String
  originalName    String        @map("original_name")
  mimeType        String        @map("mime_type")
  sizeBytes       Int           @map("size_bytes")
  createdAt       DateTime      @default(now()) @map("created_at")

  @@map("documents")
}

model Notification {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  user            User                @relation("NotificationRecipient", fields: [userId], references: [id])
  type            NotificationType
  title           String
  message         String
  linkUrl         String?             @map("link_url")
  statusProjectId String?             @map("status_project_id")
  statusProject   StatusProject?      @relation(fields: [statusProjectId], references: [id])
  // Tracks which resource triggered this (used for PoP dedup)
  sourceResourceId String?            @map("source_resource_id")
  read            Boolean             @default(false)
  emailSent       Boolean             @default(false) @map("email_sent")
  createdAt       DateTime            @default(now()) @map("created_at")

  @@map("notifications")
}

model NotificationPreference {
  id     String           @id @default(uuid())
  userId String           @map("user_id")
  user   User             @relation("NotificationPreferenceUser", fields: [userId], references: [id])
  type   NotificationType
  inApp  Boolean          @default(true) @map("in_app")
  email  Boolean          @default(true)

  @@unique([userId, type])
  @@map("notification_preferences")
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTAKE — Customer submission and review workflow
// ═══════════════════════════════════════════════════════════════════════════════

model IntakeSubmission {
  id              String       @id @default(uuid())
  submitterId     String       @map("submitter_id")
  submitter       User         @relation("IntakeSubmitter", fields: [submitterId], references: [id])

  title           String
  status          IntakeStatus @default(draft)

  currentVersionId String?    @unique @map("current_version_id")
  currentVersion  IntakeSubmissionVersion? @relation("CurrentVersion", fields: [currentVersionId], references: [id])

  // AI scoring (reviewer-only visibility)
  aiScore         Float?       @map("ai_score")
  aiScoreDetails  Json?        @map("ai_score_details")
  aiScoredAt      DateTime?    @map("ai_scored_at")

  // Leadership determination
  determination       IntakeDetermination? @map("determination")
  determinationNotes  String?              @map("determination_notes")
  denialReason        String?              @map("denial_reason")
  determinedById      String?              @map("determined_by_id")
  determinedBy        User?                @relation("IntakeDeterminer", fields: [determinedById], references: [id])
  determinedAt        DateTime?            @map("determined_at")

  // Auto-created project link
  linkedProjectId String?        @unique @map("linked_project_id")
  linkedProject   StatusProject? @relation("IntakeLinkedProject", fields: [linkedProjectId], references: [id])

  // Design review doc
  designReviewMd          String?   @map("design_review_md")
  designReviewGeneratedAt DateTime? @map("design_review_generated_at")

  // Relations
  versions    IntakeSubmissionVersion[] @relation("AllVersions")
  documents   IntakeDocument[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("intake_submissions")
}

model IntakeSubmissionVersion {
  id              String           @id @default(uuid())
  submissionId    String           @map("submission_id")
  submission      IntakeSubmission @relation("AllVersions", fields: [submissionId], references: [id], onDelete: Cascade)

  versionNumber   Int              @map("version_number")
  formData        Json             @map("form_data")

  createdAt       DateTime         @default(now()) @map("created_at")
  createdById     String           @map("created_by_id")
  createdBy       User             @relation("IntakeVersionCreator", fields: [createdById], references: [id])

  currentForSubmission IntakeSubmission? @relation("CurrentVersion")

  @@unique([submissionId, versionNumber])
  @@map("intake_submission_versions")
}

model IntakeDocument {
  id            String           @id @default(uuid())
  submissionId  String           @map("submission_id")
  submission    IntakeSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  filename      String
  originalName  String           @map("original_name")
  mimeType      String           @map("mime_type")
  sizeBytes     Int              @map("size_bytes")
  storagePath   String           @map("storage_path")

  uploadedById  String           @map("uploaded_by_id")
  uploadedBy    User             @relation("IntakeDocUploader", fields: [uploadedById], references: [id])
  uploadedAt    DateTime         @default(now()) @map("uploaded_at")

  @@map("intake_documents")
}
